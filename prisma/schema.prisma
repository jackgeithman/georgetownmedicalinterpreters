generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  INSTRUCTOR
  CLINIC
  VOLUNTEER
  PENDING
  SUPER_ADMIN // Deprecated: use ADMIN role with DEV in roles array instead
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
}

enum ShiftStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum PositionStatus {
  LOCKED     // waiting for driver to fill seat 1
  OPEN       // available for signup
  FILLED     // volunteer assigned
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum FeedbackAuthor {
  CLINIC
  VOLUNTEER
}

enum EmailRuleType {
  ALLOW
  BLOCK
}

enum NotifType {
  SIGNUP_RECEIPT
  CANCEL_RECEIPT
  REMINDER_24H
  REMINDER_8H
  REMINDER_2H
  UNFILLED_ALERT
  ADMIN_REMOVED
  SLOT_CANCELLED
  SLOT_EDITED
  CLINIC_VOLUNTEER_CANCEL
  CLINIC_UNFILLED_24H
  ADMIN_PENDING_VOLUNTEER
}

enum TrainingMaterialType {
  FILE
  LINK
}

model User {
  id                String              @id @default(uuid())
  email             String              @unique
  name              String?
  firstName         String?
  lastName          String?
  emailVerified     DateTime?
  image             String?
  role              Role                @default(PENDING)
  roles             String[]            @default([])
  status            UserStatus          @default(PENDING_APPROVAL)
  onboardingComplete Boolean            @default(false)
  clinicId          String?
  clinic            Clinic?             @relation(fields: [clinicId], references: [id])
  volunteer         VolunteerProfile?
  accounts          Account[]
  clearancesGiven   ClearanceLog[]      @relation("ClearancesGiven")
  uploadedMaterials TrainingMaterial[]  @relation("UploadedMaterials")
  suggestions       Suggestion[]        @relation("Suggestions")
  postedShifts      Shift[]             @relation("PostedShifts")
  createdAt         DateTime            @default(now())
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Clinic {
  id                       String            @id @default(uuid())
  name                     String
  address                  String
  contactName              String
  contactEmail             String
  loginToken               String            @unique @default(uuid())
  loginPin                 String            @default("000000")
  urgentCancellationAlerts Boolean           @default(true)
  travelMinutes            Int               @default(30)
  staff                    User[]
  shifts                   Shift[]
  notifPrefs               ClinicNotifPrefs?
  createdAt                DateTime          @default(now())
}

model VolunteerProfile {
  id                     String               @id @default(uuid())
  userId                 String               @unique
  user                   User                 @relation(fields: [userId], references: [id])
  languages              String[]
  backgroundInfo         String?
  hoursVolunteered       Int                  @default(0)
  drivingHours           Int                  @default(0)
  driverCleared          Boolean              @default(false)
  cancellationsWithin24h Int                  @default(0)
  cancellationsWithin2h  Int                  @default(0)
  noShows                Int                  @default(0)
  isCleared              Boolean              @default(false)
  clearedById            String?
  clearedAt              DateTime?
  positions              ShiftPosition[]
  notifPrefs             VolunteerNotifPrefs?
  clearanceLogs          ClearanceLog[]
  createdAt              DateTime             @default(now())
}

model ClearanceLog {
  id           String           @id @default(uuid())
  volunteerId  String
  volunteer    VolunteerProfile @relation(fields: [volunteerId], references: [id])
  clearedById  String?
  clearedBy    User?            @relation("ClearancesGiven", fields: [clearedById], references: [id])
  isCleared    Boolean
  note         String?
  languageCode String?          // null = general clearance (legacy), set = per-language clearance
  createdAt    DateTime         @default(now())
  notifiedAt   DateTime?        // set when volunteer dismisses the clearance ribbon
}

model Shift {
  id              String          @id @default(uuid())
  clinicId        String
  clinic          Clinic          @relation(fields: [clinicId], references: [id])
  date            DateTime
  volunteerStart  Int             // XX1: minutes from midnight (e.g. 540 = 9:00 AM)
  volunteerEnd    Int             // XX2: minutes from midnight
  travelMinutes   Int             // t: copied from clinic at creation, can be overridden
  languagesNeeded String[]        // e.g. ["ES", "ZH"] — total language needs for this shift
  notes           String?
  status          ShiftStatus     @default(ACTIVE)
  postedById      String
  postedBy        User            @relation("PostedShifts", fields: [postedById], references: [id])
  positions       ShiftPosition[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ShiftPosition {
  id             String           @id @default(uuid())
  shiftId        String
  shift          Shift            @relation(fields: [shiftId], references: [id])
  positionNumber Int              // 1 = driver seat, 2+ = interpreter seats
  isDriver       Boolean          @default(false)
  languageCode   String?          // null until assigned; set when driver fills seat 1
  volunteerId    String?
  volunteer      VolunteerProfile? @relation(fields: [volunteerId], references: [id])
  status         PositionStatus   @default(OPEN)
  signedUpAt     DateTime?
  cancelledAt    DateTime?
  feedback       Feedback[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model EmailRule {
  id        String        @id @default(uuid())
  email     String        @unique
  type      EmailRuleType
  note      String?
  createdAt DateTime      @default(now())
}

model Feedback {
  id         String         @id @default(uuid())
  positionId String
  position   ShiftPosition  @relation(fields: [positionId], references: [id])
  authorRole FeedbackAuthor
  rating     Int?           // 1-5 stars
  note       String
  createdAt  DateTime       @default(now())
}

model Suggestion {
  id            String   @id @default(uuid())
  type          String   @default("FEATURE")  // "FEATURE" | "BUG" | "GENERAL"
  subject       String
  message       String
  submittedById String?
  submittedBy   User?    @relation("Suggestions", fields: [submittedById], references: [id])
  status        String   @default("OPEN")     // "OPEN" | "NOTED" | "CLOSED"
  adminNote     String?
  createdAt     DateTime @default(now())
}

model VolunteerNotifPrefs {
  id                  String           @id @default(uuid())
  volunteerId         String           @unique
  volunteer           VolunteerProfile @relation(fields: [volunteerId], references: [id])
  signupReceipt       Boolean          @default(true)
  cancellationReceipt Boolean          @default(true)
  reminder24h         Boolean          @default(true)
  unfilledSlotAlert   Boolean          @default(false)
  updatedAt           DateTime         @updatedAt
}

model NotifLog {
  id             String    @id @default(uuid())
  type           NotifType
  recipientEmail String
  positionId     String?
  shiftId        String?
  sentAt         DateTime  @default(now())
}

model ClinicNotifPrefs {
  id                    String   @id @default(uuid())
  clinicId              String   @unique
  clinic                Clinic   @relation(fields: [clinicId], references: [id])
  dailySummary          Boolean  @default(true)
  unfilledAlert24h      Boolean  @default(true)
  volunteerCancelWindow Int?
  updatedAt             DateTime @updatedAt
}

model LanguageConfig {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model TrainingMaterial {
  id           String               @id @default(uuid())
  title        String
  description  String?
  type         TrainingMaterialType
  url          String
  fileName     String?
  languageCode String?
  category     String               @default("General")
  uploadedById String?
  uploadedBy   User?                @relation("UploadedMaterials", fields: [uploadedById], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(uuid())
  actorId    String?  // null = system
  actorEmail String?
  actorName  String?
  action     String   // e.g. "ROLE_ADDED", "SIGNUP_CREATED", "SLOT_CANCELLED"
  targetType String?  // e.g. "User", "Slot", "Signup"
  targetId   String?
  detail     String?  // human-readable summary
  createdAt  DateTime @default(now())
}

model AdminNote {
  id        String   @id @default(uuid())
  key       String   @unique  // e.g. "main"
  content   String
  updatedBy String?
  updatedAt DateTime @updatedAt
}
