generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CLINIC
  VOLUNTEER
  PENDING
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
}

enum Language {
  ES
  ZH
  KO
  AR
}

enum SlotStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum SignupStatus {
  ACTIVE
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum FeedbackAuthor {
  CLINIC
  VOLUNTEER
}

enum EmailRuleType {
  ALLOW
  BLOCK
}

enum NotifType {
  SIGNUP_RECEIPT
  CANCEL_RECEIPT
  REMINDER_24H
  REMINDER_8H
  REMINDER_2H
  UNFILLED_ALERT
  ADMIN_REMOVED
  SLOT_CANCELLED
  SLOT_EDITED
  CLINIC_VOLUNTEER_CANCEL
  CLINIC_UNFILLED_24H
  ADMIN_PENDING_VOLUNTEER
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  name          String?
  emailVerified DateTime?
  image         String?
  role          Role              @default(PENDING)
  status        UserStatus        @default(PENDING_APPROVAL)
  clinicId      String?
  clinic        Clinic?           @relation(fields: [clinicId], references: [id])
  volunteer     VolunteerProfile?
  accounts      Account[]
  createdSlots  Slot[]            @relation("SlotCreatedByAdmin")
  createdAt     DateTime          @default(now())
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Clinic {
  id                       String            @id @default(uuid())
  name                     String
  address                  String
  contactName              String
  contactEmail             String
  loginToken               String            @unique @default(uuid())
  loginPin                 String            @default("000000")
  urgentCancellationAlerts Boolean           @default(true)
  staff                    User[]
  slots                    Slot[]
  notifPrefs               ClinicNotifPrefs?
  createdAt                DateTime          @default(now())
}

model VolunteerProfile {
  id                     String               @id @default(uuid())
  userId                 String               @unique
  user                   User                 @relation(fields: [userId], references: [id])
  languages              Language[]
  backgroundInfo         String?
  hoursVolunteered       Int                  @default(0)
  cancellationsWithin24h Int                  @default(0)
  cancellationsWithin2h  Int                  @default(0)
  noShows                Int                  @default(0)
  signups                SubBlockSignup[]
  notifPrefs             VolunteerNotifPrefs?
  createdAt              DateTime             @default(now())
}

model Slot {
  id                String         @id @default(uuid())
  clinicId          String
  clinic            Clinic         @relation(fields: [clinicId], references: [id])
  language          Language
  date              DateTime
  startTime         Int
  endTime           Int
  interpreterCount  Int
  isRecurring       Boolean        @default(false)
  recurrenceGroupId String?
  notes             String?
  status            SlotStatus     @default(ACTIVE)
  signups           SubBlockSignup[]
  createdByAdminId  String?
  createdByAdmin    User?          @relation("SlotCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdAt         DateTime       @default(now())
}

model SubBlockSignup {
  id          String           @id @default(uuid())
  slotId      String
  slot        Slot             @relation(fields: [slotId], references: [id])
  volunteerId String
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id])
  subBlockHour Int
  status      SignupStatus     @default(ACTIVE)
  cancelledAt DateTime?
  feedback    Feedback[]
  createdAt   DateTime         @default(now())
}

model EmailRule {
  id        String        @id @default(uuid())
  email     String        @unique
  type      EmailRuleType
  note      String?
  createdAt DateTime      @default(now())
}

model Feedback {
  id         String         @id @default(uuid())
  signupId   String
  signup     SubBlockSignup @relation(fields: [signupId], references: [id])
  authorRole FeedbackAuthor
  note       String
  createdAt  DateTime       @default(now())
}

model VolunteerNotifPrefs {
  id                  String           @id @default(uuid())
  volunteerId         String           @unique
  volunteer           VolunteerProfile @relation(fields: [volunteerId], references: [id])
  signupReceipt       Boolean          @default(true)
  cancellationReceipt Boolean          @default(true)
  reminder24h         Boolean          @default(true)
  unfilledSlotAlert   Boolean          @default(false)
  updatedAt           DateTime         @updatedAt
}

model NotifLog {
  id             String    @id @default(uuid())
  type           NotifType
  recipientEmail String
  signupId       String?
  slotId         String?
  sentAt         DateTime  @default(now())
}

model ClinicNotifPrefs {
  id                    String   @id @default(uuid())
  clinicId              String   @unique
  clinic                Clinic   @relation(fields: [clinicId], references: [id])
  dailySummary          Boolean  @default(true)
  unfilledAlert24h      Boolean  @default(true)
  volunteerCancelWindow Int?
  updatedAt             DateTime @updatedAt
}
