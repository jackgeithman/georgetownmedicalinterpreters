# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://georgetownmedicalinterpreters.org

# Super admin email — this account always gets the SUPER_ADMIN role
SUPER_ADMIN_EMAIL=

# Comma-separated list of non-@georgetown.edu emails allowed to sign in (optional)
ALLOWED_EXTRA_EMAILS=
